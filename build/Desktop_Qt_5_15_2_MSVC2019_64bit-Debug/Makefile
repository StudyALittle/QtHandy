..\..\QtHandy.pro:
qmake: FORCE
	@$(QMAKE) -o Makefile ..\..\QtHandy.pro -spec win32-msvc "CONFIG+=debug" "CONFIG+=qml_debug"

qmake_all: sub-DirFileTool-qmake_all sub-Example-qmake_all sub-QtHandy-qmake_all sub-Test-qmake_all FORCE

make_first: sub-DirFileTool-make_first sub-Example-make_first sub-QtHandy-make_first sub-Test-make_first  FORCE
all: sub-DirFileTool-all sub-Example-all sub-QtHandy-all sub-Test-all  FORCE
clean: sub-DirFileTool-clean sub-Example-clean sub-QtHandy-clean sub-Test-clean  FORCE
distclean: sub-DirFileTool-distclean sub-Example-distclean sub-QtHandy-distclean sub-Test-distclean  FORCE
	-$(DEL_FILE) Makefile
	-$(DEL_FILE) .qmake.stash
install_subtargets: sub-DirFileTool-install_subtargets sub-Example-install_subtargets sub-QtHandy-install_subtargets sub-Test-install_subtargets FORCE
uninstall_subtargets: sub-DirFileTool-uninstall_subtargets sub-Example-uninstall_subtargets sub-QtHandy-uninstall_subtargets sub-Test-uninstall_subtargets FORCE

sub-DirFileTool-debug:
	@if not exist DirFileTool\ mkdir DirFileTool\ & if not exist DirFileTool\ exit 1
	@set MAKEFLAGS=$(MAKEFLAGS)
	cd DirFileTool\ && ( if not exist Makefile $(QMAKE) -o Makefile D:\Project\Qt\QtHandy\DirFileTool\DirFileTool.pro -spec win32-msvc "CONFIG+=debug" "CONFIG+=qml_debug" ) && $(MAKE) -f Makefile debug
sub-Example-debug:
	@if not exist Example\ mkdir Example\ & if not exist Example\ exit 1
	@set MAKEFLAGS=$(MAKEFLAGS)
	cd Example\ && ( if not exist Makefile $(QMAKE) -o Makefile D:\Project\Qt\QtHandy\Example\Example.pro -spec win32-msvc "CONFIG+=debug" "CONFIG+=qml_debug" ) && $(MAKE) -f Makefile debug
sub-QtHandy-debug:
	@if not exist QtHandy\ mkdir QtHandy\ & if not exist QtHandy\ exit 1
	@set MAKEFLAGS=$(MAKEFLAGS)
	cd QtHandy\ && ( if not exist Makefile $(QMAKE) -o Makefile D:\Project\Qt\QtHandy\QtHandy\QtHandy.pro -spec win32-msvc "CONFIG+=debug" "CONFIG+=qml_debug" ) && $(MAKE) -f Makefile debug
sub-Test-debug:
	@if not exist Test\ mkdir Test\ & if not exist Test\ exit 1
	@set MAKEFLAGS=$(MAKEFLAGS)
	cd Test\ && ( if not exist Makefile $(QMAKE) -o Makefile D:\Project\Qt\QtHandy\Test\Test.pro -spec win32-msvc "CONFIG+=debug" "CONFIG+=qml_debug" ) && $(MAKE) -f Makefile debug
debug: sub-DirFileTool-debug sub-Example-debug sub-QtHandy-debug sub-Test-debug

